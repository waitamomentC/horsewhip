{
  "name": "horsewhip",
  "displayName": "Horsewhip",
  "description": "File-lane timeline + dual whip guards: aim on graph, instant revert on illegal writes, boundary metadata in .git/horsewhip—expand fence in UI before editing outside.",
  "version": "2.0.1",
  "publisher": "horsewhip",
  "license": "AGPL-3.0-or-later",
  "icon": "media/horsewhip-icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waitamomentC/horsewhip.git"
  },
  "homepage": "https://github.com/waitamomentC/horsewhip#readme",
  "bugs": {
    "url": "https://github.com/waitamomentC/horsewhip/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onView:horsewhip.timelineView",
    "workspaceContains:**/.git/HEAD"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "horsewhip",
          "title": "Horsewhip",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "views": {
      "horsewhip": [
        {
          "id": "horsewhip.timelineView",
          "name": "Horsewhip",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "horsewhip.timelineView",
        "contents": "Git file swimlanes · dual whip guards (aim + write lock).\n[Open Horsewhip timeline](command:horsewhip.open)"
      }
    ],
    "commands": [
      {
        "command": "horsewhip.open",
        "title": "Horsewhip: Open Timeline",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.showTimeline",
        "title": "Horsewhip: Open Timeline",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.refresh",
        "title": "Horsewhip: Refresh Git Log",
        "icon": "$(refresh)"
      },
      {
        "command": "horsewhip.loadDemo",
        "title": "Horsewhip: Load Demo Data",
        "icon": "$(beaker)"
      },
      {
        "command": "horsewhip.publishGithub",
        "title": "Horsewhip: Publish to GitHub (SSH)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "horsewhip.commit",
        "title": "Horsewhip: Commit Changes",
        "icon": "$(git-commit)"
      },
      {
        "command": "horsewhip.checkBoundary",
        "title": "Horsewhip: Check Boundary (Guard)",
        "icon": "$(shield)"
      },
      {
        "command": "horsewhip.insertCorrection",
        "title": "Horsewhip: Insert Overreach Correction to Chat",
        "icon": "$(warning)"
      },
      {
        "command": "horsewhip.revertOverreach",
        "title": "Horsewhip: Revert Overreach Files",
        "icon": "$(discard)"
      },
      {
        "command": "horsewhip.installCommitHook",
        "title": "Horsewhip: Install Git Pre-Commit Guard Hook",
        "icon": "$(shield)"
      }
    ],
    "configuration": {
      "title": "Horsewhip",
      "properties": {
        "horsewhip.guard.onSave": {
          "type": "boolean",
          "default": true,
          "description": "保存文件时自动检查工作区改动是否超出 horsewhip 划定的边界。"
        },
        "horsewhip.guard.mode": {
          "type": "string",
          "enum": [
            "warn",
            "strict"
          ],
          "default": "warn",
          "enumDescriptions": [
            "越界时轻量通知，可点「插入纠正」",
            "保存时若越界则弹出完整处理对话框"
          ],
          "description": "守门严格程度。"
        },
        "horsewhip.guard.blockCommit": {
          "type": "boolean",
          "default": true,
          "description": "已划定边界且存在越界时，拦截 horsewhip 内提交与 git pre-commit。"
        },
        "horsewhip.guard.blockCommitWithoutBoundary": {
          "type": "boolean",
          "default": true,
          "description": "未在泳道划边界时拦截 commit（推荐开启，避免误以为已守门）。"
        },
        "horsewhip.guard.installHookOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "打开工作区时自动安装 .git/hooks/pre-commit 守门脚本。"
        },
        "horsewhip.guard.revertOnCommitBlock": {
          "type": "string",
          "enum": [
            "prompt",
            "always",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "人在回路：commit 被拦后弹窗选择（适合用户坐在 IDE 前）",
            "全自动默认：被拦后立即还原越界文件（适合 vibe agent，不问用户）",
            "仅拦截 commit，不还原（不推荐）"
          ],
          "description": "commit 因越界失败后是否还原工作区。全自动代理请保持 always。"
        },
        "horsewhip.guard.notifyOnCommitBlock": {
          "type": "boolean",
          "default": false,
          "description": "always 模式下仍弹出通知条（默认 false，仅状态栏 + 顶栏，少打断全自动 agent）。"
        },
        "horsewhip.guard.offerCorrectionAfterRevert": {
          "type": "boolean",
          "default": true,
          "description": "还原越界文件后，自动把「边界内重想」纠正文案插入 Chat。"
        },
        "horsewhip.guard.blockEdit": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "lock"
          ],
          "default": "lock",
          "enumDescriptions": [
            "不拦编辑器（仅靠 commit；未圈定仍可手改，不推荐）",
            "打开文件时提示",
            "默认：未圈定=全库只读；已圈定=仅圈内可改"
          ],
          "description": "编辑期守门：未挥鞭圈定则禁止改任何文件；圈定后仅圈内路径可编辑。commit 守门始终生效。"
        },
        "horsewhip.guard.offerEditBlockToChat": {
          "type": "boolean",
          "default": true,
          "description": "编辑被拦时，用户点「插入说明到 Chat」是否写入 AI 可读文案。"
        },
        "horsewhip.guard.revertOnWrite": {
          "type": "boolean",
          "default": true,
          "description": "未圈定或圈外路径一旦被写入（含 Agent 直写盘），立即 git 还原，不等到 commit。"
        },
        "horsewhip.guard.notifyAiOnWrite": {
          "type": "boolean",
          "default": true,
          "description": "写盘被拦并还原后，自动向 Chat 插入说明，要求 AI 询问用户是否圈定/授权。"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "horsewhip.open"
        },
        {
          "command": "horsewhip.refresh"
        },
        {
          "command": "horsewhip.loadDemo"
        },
        {
          "command": "horsewhip.publishGithub"
        },
        {
          "command": "horsewhip.commit"
        },
        {
          "command": "horsewhip.checkBoundary"
        },
        {
          "command": "horsewhip.insertCorrection"
        },
        {
          "command": "horsewhip.revertOverreach"
        },
        {
          "command": "horsewhip.installCommitHook"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "build:web": "cd .. && npm run build:web",
    "build:all": "npm run build:web && npm run sync-assets && npm run compile",
    "build:extension": "npm run build:all",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "sync-assets": "node ./scripts/sync-web-assets.js",
    "bump:build": "node ./scripts/bump-build.mjs",
    "package": "npm run bump:build && npm run sync-assets && npm run compile && vsce package --no-dependencies",
    "publish:marketplace": "npm run build:all && vsce publish --no-dependencies",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.4.0"
  }
}
