{
  "name": "horsewhip",
  "displayName": "Horsewhip",
  "description": "Git file timeline · GitHub SSH publish · workspace git only",
  "version": "ve.0.0",
  "publisher": "horsewhip",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onView:horsewhip.timelineView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "horsewhip",
          "title": "Horsewhip",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "views": {
      "horsewhip": [
        {
          "id": "horsewhip.timelineView",
          "name": "Horsewhip",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "horsewhip.timelineView",
        "contents": "Git file swimlane timeline. Open in editor.\n[Open Horsewhip workspace](command:horsewhip.open)"
      }
    ],
    "commands": [
      {
        "command": "horsewhip.open",
        "title": "Horsewhip: Open Timeline",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.showTimeline",
        "title": "Horsewhip: Open Timeline",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.refresh",
        "title": "Horsewhip: Refresh Git Log",
        "icon": "$(refresh)"
      },
      {
        "command": "horsewhip.loadDemo",
        "title": "Horsewhip: Load Demo Data",
        "icon": "$(beaker)"
      },
      {
        "command": "horsewhip.publishGithub",
        "title": "Horsewhip: Publish to GitHub (SSH)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "horsewhip.commit",
        "title": "Horsewhip: Commit Changes",
        "icon": "$(git-commit)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "horsewhip.open"
        },
        {
          "command": "horsewhip.refresh"
        },
        {
          "command": "horsewhip.loadDemo"
        },
        {
          "command": "horsewhip.publishGithub"
        },
        {
          "command": "horsewhip.commit"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "sync-assets": "node ./scripts/sync-web-assets.js",
    "package": "npm run sync-assets && npm run compile && vsce package --no-dependencies",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.4.0"
  }
}
