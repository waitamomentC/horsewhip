{
  "name": "horsewhip",
  "displayName": "马鞭 · Horsewhip",
  "description": "Git file timeline · GitHub SSH publish · workspace git only",
  "version": "0.4.9",
  "publisher": "horsewhip",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onView:horsewhip.timelineView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "horsewhip",
          "title": "马鞭",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "views": {
      "horsewhip": [
        {
          "id": "horsewhip.timelineView",
          "name": "Horsewhip",
          "icon": "media/horsewhip.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "horsewhip.timelineView",
        "contents": "Git 文件泳道时间线，全屏工作区打开。\n[打开马鞭工作区](command:horsewhip.open)"
      }
    ],
    "commands": [
      {
        "command": "horsewhip.open",
        "title": "马鞭: 打开时间线",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.showTimeline",
        "title": "马鞭: 打开时间线",
        "icon": "$(symbol-event)"
      },
      {
        "command": "horsewhip.refresh",
        "title": "马鞭: 刷新 Git 记录",
        "icon": "$(refresh)"
      },
      {
        "command": "horsewhip.loadDemo",
        "title": "马鞭: 加载演示数据",
        "icon": "$(beaker)"
      },
      {
        "command": "horsewhip.publishGithub",
        "title": "马鞭: 发布到 GitHub (SSH)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "horsewhip.commit",
        "title": "马鞭: 提交更改",
        "icon": "$(git-commit)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "horsewhip.open"
        },
        {
          "command": "horsewhip.refresh"
        },
        {
          "command": "horsewhip.loadDemo"
        },
        {
          "command": "horsewhip.publishGithub"
        },
        {
          "command": "horsewhip.commit"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "sync-assets": "node ./scripts/sync-web-assets.js",
    "package": "npm run sync-assets && npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.4.0"
  }
}
